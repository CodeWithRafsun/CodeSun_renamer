#!/usr/bin/env bash

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Loading Bar Animation
echo -e "${CYAN}Starting RENAMER...${NC}"
for i in {1..20}; do
    printf "${GREEN}█${NC}"
    sleep 0.05
done
echo -e " ${YELLOW}100%${NC}\n"
sleep 0.3

# Clear screen and start Python script
clear
python "$DIR/main.py"
